{
  "manifest_version": 3,
  "name": "Shopee AI Draft Helper",
  "version": "1.1.0",
  "description": "Fill Shopee Seller Center fields using AI-generated drafts from n8n.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://seller.shopee.com/*",
    "https://seller.shopee.kr/*",
    "https://seller.shopee.co.kr/*",
    "https://seller.shopee.sg/*",
    "https://seller.shopee.com.my/*",
    "https://seller.shopee.ph/*",
    "https://seller.shopee.co.th/*",
    "https://seller.shopee.vn/*",
    "https://seller.shopee.co.id/*",
    "https://*.shopee.com/*",
    "https://*.shopee.kr/*",
    "https://n8n-6txh.srv1651644.hstgr.cloud/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopee AI Draft Helper"
  },
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://seller.shopee.com/*",
        "https://seller.shopee.kr/*",
        "https://seller.shopee.co.kr/*",
        "https://seller.shopee.sg/*",
        "https://seller.shopee.com.my/*",
        "https://seller.shopee.ph/*",
        "https://seller.shopee.co.th/*",
        "https://seller.shopee.vn/*",
        "https://seller.shopee.co.id/*",
        "https://*.shopee.com/*",
        "https://*.shopee.kr/*"
      ],
      "js": ["shopeeContentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
